  "staticComponents": false,
  "version": "1.0",
  "standardVersion": "1.0",
  "formatVersion": "1.0",
  "language": "C++",
  "author": "Gleb Chekmarev/glChek",
  "visual": true,
  "compile": true,
  "mainFileExtension": "cpp",
  "staticActionDelimeter": "::",
  "headerFileExtension": "hpp",
  "compilingSettings": [
    {
      "command": "make",
      "flags": [
        "-C",
        "{library_dir}/IRPCB/1.0/source",
        "build_Fromboot",
        "EXTRA_DIR={base_dir}/",
        "BUILD_DIR={base_dir}/build",
        "OUT_DIR={artifacts_dir}/IRPCB"
      ]
    }
  ],
  "mainFunction": true,
  "delimeter": ";",
  "defaultIncludeFiles": [
    "InitFunctions.hpp",
    "board.h"
  ],
  "defaultBuildFiles": [],

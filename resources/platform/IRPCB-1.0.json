      "constructorParameters": {
        "Контакт": {
          "type": [
            "LED_PWM1",
            "LED_PWM2",
            "LED_PWM3",
            "LED_PWM4",
            "LED_FRONT1",
            "LED_FRONT2"
          ],
          "description": "Контакт платы, к которому подключен светодиод",
          "valueAlias": [
            "PIN_LED1",
            "PIN_LED2",
            "PIN_LED3",
            "PIN_LED4",
            "PIN_FRONT_LED1",
            "PIN_FRONT_LED2"
          ]
        }
      },
      "variables": {},
      "methods": {
        "set": {
          "alias": "Установить яркость",
          "img": "tjc-ms/setBright.svg",
          "parameters": [
            {
              "name": "Яркость",
              "type": "uint32_t",
              "description": "Яркость (от 0 до 255)",
              "optional": false
            }
          ],
          "description": "Установить яркость светодиода"
        },
        "on": {
          "alias": "Включить",
          "img": "arduino/switch-on.svg",
          "description": "Включить светодиод на полную яркость"
        },
        "off": {
          "alias": "Погасить",
          "img": "arduino/switch-off.svg",
          "description": "Выключить светодиод"
        },
        "toggle": {
          "alias": "Переключить",
          "img": "arduino/toggle.svg",
          "description": "Поменять состояние светодиода на противоположное (включённый выключить, выключенный включить)"
        },
        "fadeTo": {
          "alias": "Плавно изменить яркость",
          "img": "irpcb/fadeTo.svg",
          "parameters": [
            {
              "name": "Продолжительность",
              "type": "uint32_t",
              "description": "Целое число в миллисекундах",
              "optional": false
            },
            {
              "name": "Яркость",
              "type": "uint32_t",
              "description": "Число от 0 до 255. 0 = выключено, 255 = самая яркая",
              "optional": false
            }
          ],
          "description": "Плавно меняет яркость до нужного уровня за указанное время"
        },
        "fadeIn": {
          "alias": "Плавно включить",
          "img": "irpcb/fadeIn.svg",
          "parameters": [
            {
              "name": "Продолжительность",
              "type": "uint32_t",
              "description": "Целое число в миллисекундах",
              "optional": false
            }
          ],
          "description": "Плавно делает светодиод ярким за указанное время"
        },
        "fadeOut": {
          "alias": "Плавно выключить",
          "img": "irpcb/fadeOut.svg",
          "parameters": [
            {
              "name": "Продолжительность",
              "type": "uint32_t",
              "description": "Целое число в миллисекундах",
              "optional": false
            }
          ],
          "description": "Плавно гасит светодиод за указанное время"
        },
        "blink": {
          "alias": "Помигать",
          "img": "arduino/blink.svg",
          "parameters": [
            {
              "name": "Время мигания",
              "type": "uint32_t",
              "description": "Время, которое в общем будет мигать светодиод (мс)"
            },
            {
              "name": "Время одного мигания",
              "type": "uint32_t",
              "description": "Длительность одного мигания, включения и выключения (мс)"
            }
